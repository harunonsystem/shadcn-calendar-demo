{
  "name": "shadcn-calendar-demo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "vite",
    "build": "bun run tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --fix",
    "fmt": "oxfmt --write src",
    "fmt:check": "oxfmt --check src",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "ci": "bun run lint && bun run fmt:check && bun run typecheck && bun run test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy:storybook": "bun run build-storybook && wrangler deploy --config wrangler.storybook.jsonc"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jotai": "^2.12.3",
    "lucide-react": "^0.577.0",
    "nuqs": "^2.8.6",
    "react": "^19.0.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "^4.0.16",
    "happy-dom": "^20.0.11",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.0.0",
    "playwright": "^1.57.0",
    "storybook": "^10.1.11",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.16"
  }
}
